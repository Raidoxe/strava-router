# Copy to /etc/strava-router/deploy.env and `chmod 600` it.
# Used by strava-deploy.service (the webhook listener).

# A long random string. Paste the SAME value into GitHub:
#   Repo -> Settings -> Webhooks -> Add webhook -> Secret
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=REPLACE_ME_WITH_64_HEX_CHARS

# Branch to react to (others are ignored).
DEPLOY_BRANCH=main

# Where the repo lives. Must match the systemd service WorkingDirectory.
REPO_DIR=/srv/strava-router

# Port the listener binds to (mapped through Caddy / Cloudflare Tunnel).
DEPLOY_PORT=9001
